generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Deal {
  id            String   @id @default(uuid())
  title         String
  price_cents   Int
  marketplace   String
  url_affiliate String
  rating        Float?
  review_count  Int?
  seller_name   String?
  category      String?
  images        String[] // Uses native array in PostgreSQL
  url_canonical String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("deals")
}

model Admin {
  id         String   @id @default(uuid())
  email      String   @unique
  password   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("admins")
}

model MessageQueue {
  id           String    @id @default(uuid())
  channel      String    // "whatsapp" | "telegram" | "both"
  title        String    @default("")
  body         String
  image_url    String    @default("")
  link         String    @default("")
  status       String    @default("pending") // pending | scheduled | sent | failed | cancelled
  scheduled_at DateTime?
  sent_at      DateTime?
  deal_id      String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@map("message_queue")
}

model AutoSendConfig {
  id                       String  @id @default("singleton")
  enabled                  Boolean @default(false)
  interval_minutes         Int     @default(30)
  channels                 String  @default("both") // "whatsapp" | "telegram" | "both"
  auto_generate_from_deals Boolean @default(true)

  @@map("auto_send_config")
}
