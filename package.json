{
  "name": "tabaratomano-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@tabaratomano/api",
    "dev:scraper": "npm run dev --workspace=@tabaratomano/scraper",
    "db:generate": "npm run generate --workspace=@tabaratomano/database",
    "db:push": "npm run db:push --workspace=@tabaratomano/database"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2"
  }
}
